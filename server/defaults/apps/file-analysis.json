{
  "id": "file-analysis",
  "name": {
    "en": "File Analyzer",
    "de": "Dateianalyse"
  },
  "description": {
    "en": "Upload and analyze files with AI",
    "de": "Dateien hochladen und mit KI analysieren"
  },
  "color": "#10B981",
  "icon": "camera",
  "type": "chat",
  "system": {
    "en": "You are an AI file analysis assistant. Your role is to analyze files that users upload and provide detailed insights about what you see. Be detailed, accurate, and helpful.",
    "de": "Du bist ein KI-Dateianalyseassistent. Deine Aufgabe ist es, von Benutzern hochgeladene Dateien zu analysieren und detaillierte Einblicke zu geben, was du siehst. Sei detailliert, genau und hilfreich."
  },
  "tokenLimit": 32768,
  "order": 10,
  "preferredOutputFormat": "markdown",
  "preferredStyle": "detailed",
  "preferredTemperature": 1.0,
  "sendChatHistory": true,
  "upload": {
    "enabled": true,
    "imageUpload": {
      "enabled": true,
      "resizeImages": true,
      "maxFileSizeMB": 10,
      "supportedFormats": [
        "image/jpeg",
        "image/jpg",
        "image/png",
        "image/gif",
        "image/webp",
        "image/tiff",
        "image/tif"
      ]
    },
    "fileUpload": {
      "enabled": true,
      "maxFileSizeMB": 5,
      "supportedFormats": [
        "text/plain",
        "text/markdown",
        "text/csv",
        "application/json",
        "text/html",
        "text/css",
        "text/javascript",
        "application/javascript",
        "text/xml",
        "message/rfc822",
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/vnd.ms-excel",
        "application/vnd.ms-powerpoint",
        "application/vnd.ms-outlook",
        "application/x-msg",
        "application/vnd.oasis.opendocument.text",
        "application/vnd.oasis.opendocument.spreadsheet",
        "application/vnd.oasis.opendocument.presentation"
      ]
    },
    "allowMultiple": true,
    "audioUpload": {
      "enabled": true
    },
    "cloudStorageUpload": {
      "enabled": true
    }
  },
  "disallowModelSelection": false,
  "allowEmptyContent": false,
  "autoStart": false,
  "enabled": true,
  "allowInheritance": false,
  "tools": [],
  "greeting": {
    "en": {
      "title": "👋 Hello!",
      "subtitle": "How can I help you today?"
    },
    "de": {
      "title": "👋 Hallo!",
      "subtitle": "Wie kann ich Ihnen heute helfen?"
    }
  },
  "inputMode": {
    "type": "singleline",
    "rows": 5,
    "microphone": {
      "enabled": true,
      "mode": "manual",
      "showTranscript": true
    }
  }
}
