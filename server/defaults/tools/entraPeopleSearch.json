{
  "id": "entraPeopleSearch",
  "name": {
    "en": "Entra People Search",
    "de": "Entra Personensuche"
  },
  "description": {
    "en": "Query the corporate directory for people and teams",
    "de": "Durchsuchen Sie das Unternehmensverzeichnis nach Personen und Teams"
  },
  "script": "entraPeopleSearch.js",
  "functions": {
    "findUser": {
      "description": {
        "en": "Find a user by name or email",
        "de": "Einen Benutzer nach Name oder E-Mail finden"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": {
              "en": "User name or email",
              "de": "Benutzername oder E-Mail"
            }
          }
        },
        "required": ["name"]
      }
    },
    "getAllUserDetails": {
      "description": {
        "en": "Get all details for a user",
        "de": "Alle Details für einen Benutzer abrufen"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": {
              "en": "User identifier",
              "de": "Benutzerkennung"
            }
          }
        },
        "required": ["userId"]
      }
    },
    "getUserManager": {
      "description": {
        "en": "Get the direct manager of a user",
        "de": "Den direkten Vorgesetzten eines Benutzers abrufen"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": {
              "en": "User identifier",
              "de": "Benutzerkennung"
            }
          }
        },
        "required": ["userId"]
      }
    },
    "getUserGroups": {
      "description": {
        "en": "List teams the user belongs to",
        "de": "Teams auflisten, denen der Benutzer angehört"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": {
              "en": "User identifier",
              "de": "Benutzerkennung"
            }
          }
        },
        "required": ["userId"]
      }
    },
    "getTeamMembers": {
      "description": {
        "en": "Get members of a team",
        "de": "Mitglieder eines Teams abrufen"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "teamId": {
            "type": "string",
            "description": {
              "en": "Team identifier",
              "de": "Team-Kennung"
            }
          }
        },
        "required": ["teamId"]
      }
    },
    "getUserPhotoBase64": {
      "description": {
        "en": "Get a user's profile photo as Base64",
        "de": "Profilbild eines Benutzers als Base64 abrufen"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": {
              "en": "User identifier",
              "de": "Benutzerkennung"
            }
          }
        },
        "required": ["userId"]
      }
    }
  }
}
