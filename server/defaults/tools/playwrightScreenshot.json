{
  "id": "playwrightScreenshot",
  "name": {
    "en": "Website Screenshot (Playwright)",
    "de": "Website-Screenshot (Playwright)"
  },
  "description": {
    "en": "Take a screenshot or PDF of a webpage using Playwright.",
    "de": "Erstellen Sie einen Screenshot oder PDF einer Webseite mit Playwright."
  },
  "script": "playwrightScreenshot.js",
  "parameters": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "description": {
          "en": "Target URL",
          "de": "Ziel-URL"
        }
      },
      "format": {
        "type": "string",
        "enum": ["png", "pdf"],
        "default": "png",
        "description": {
          "en": "Output format (png or pdf)",
          "de": "Ausgabeformat (png oder pdf)"
        }
      },
      "fullPage": {
        "type": "boolean",
        "default": true,
        "description": {
          "en": "Capture full page or just visible area",
          "de": "Ganze Seite oder nur sichtbaren Bereich erfassen"
        }
      }
    },
    "required": ["url"]
  }
}
